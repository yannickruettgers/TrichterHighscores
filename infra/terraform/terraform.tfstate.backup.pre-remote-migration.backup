        {
          "schema_version": 0,
          "attributes": {
            "arn": "arn:aws:cloudfront::888577064621:function/trichter-me-prod-frontend-rewrite",
            "code": "function handler(event) {\n  var request = event.request;\n  var uri = request.uri;\n\n  if (uri.endsWith('/')) {\n    request.uri += 'index.html';\n  } else if (!uri.includes('.')) {\n    request.uri += '/index.html';\n  }\n\n  return request;\n}\n",
            "comment": "Rewrite extensionless paths to nested index.html files",
            "etag": "ETVPDKIKX0DER",
