---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Festival-Highscores auf trichter.me" } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#030817" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/branding/logo-mascot.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
