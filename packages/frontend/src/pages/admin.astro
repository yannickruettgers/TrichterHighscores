---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="trichter.me | Admin">
  <main class="admin-page" x-data="adminApp()">
    <div class="neon-splash" aria-hidden="true"></div>

    <header class="board-header">
      <div class="brand-lockup">
        <div class="brand-logo-shell brand-logo-shell-small">
          <img class="brand-logo" src="/branding/logo-mascot.svg" alt="trichter.me Maskottchen" />
        </div>
        <div>
          <p class="eyebrow">Parookaville</p>
          <h1>Admin Panel</h1>
        </div>
      </div>
      <a class="button-link" href="/">Zurück zum Leaderboard</a>
    </header>

    <section class="panel admin-auth" aria-labelledby="access-title">
      <div>
        <p class="eyebrow">Geschützter Bereich</p>
        <h2 id="access-title">Highscores verwalten</h2>
        <p class="muted">Einträge sind nach der Anmeldung mit deinem Cognito-Benutzernamen nachvollziehbar.</p>
      </div>
      <div class="admin-actions">
        <button class="button-primary" type="button" @click="login()" x-show="!accessToken" x-cloak>Mit Cognito anmelden</button>
        <button type="button" @click="logout()" x-show="accessToken" x-cloak>Logout</button>
      </div>
    </section>

    <div class="status-card" x-show="statusMessage" x-cloak :class="statusIsError ? 'error-card' : ''" aria-live="polite">
      <p x-text="statusMessage"></p>
    </div>

    <section class="panel" x-show="!accessToken" x-cloak>
      <p>Bitte melde dich an, um Einträge anzulegen oder zu löschen.</p>
    </section>

    <div class="admin-content" x-show="accessToken" x-cloak>
      <section class="panel" aria-labelledby="create-title">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Neuer Versuch</p>
            <h2 id="create-title">Neuer Eintrag</h2>
          </div>
        </div>

        <form @submit.prevent="createEntry()" class="form-grid">
          <div class="form-field">
            <label for="pseudonym">Name</label>
            <input id="pseudonym" type="text" x-model="form.pseudonym" minlength="2" maxlength="32" autocomplete="off" required />
          </div>
          <div class="form-field">
            <label for="score-time">Zeit in Sekunden</label>
            <input id="score-time" type="number" x-model.number="form.time_seconds" step="0.001" min="0.001" inputmode="decimal" placeholder="1.234" required />
          </div>
          <div class="form-field">
            <label for="category">Kategorie</label>
            <select id="category" x-model="form.category" required>
              <template x-for="category in categories" :key="category"><option :value="category" x-text="category"></option></template>
            </select>
          </div>
          <div class="form-field">
            <label for="festival-day">Festivaltag</label>
            <select id="festival-day" x-model="form.festival_day" @change="syncDateFromFestivalDay()" required>
              <template x-for="day in festivalDays" :key="day"><option :value="day" x-text="dayLabel(day)"></option></template>
            </select>
          </div>
          <div class="form-field form-field-wide">
            <label for="achieved-at">Erzielt am (Europe/Berlin)</label>
            <input id="achieved-at" type="datetime-local" x-model="form.achieved_local" @change="syncFestivalDayFromDate()" step="60" required />
          </div>
          <div class="form-submit">
            <button class="button-primary" type="submit" :disabled="saving" x-text="saving ? 'Wird gespeichert…' : 'Highscore speichern'"></button>
          </div>
        </form>
      </section>

      <section class="panel" aria-labelledby="entries-title">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Audit Log</p>
            <h2 id="entries-title">Gespeicherte Einträge</h2>
          </div>
          <span class="count-chip" x-text="`${rows.length} Einträge`"></span>
        </div>

        <div class="status-card" x-show="loadingRows" x-cloak role="status">
          <strong>Einträge werden geladen...</strong>
        </div>
        <div class="status-card empty-card" x-show="!loadingRows && rows.length === 0" x-cloak>
          <strong>Noch keine Highscores vorhanden</strong>
        </div>

        <div class="table-wrap" x-show="!loadingRows && rows.length > 0" x-cloak>
          <table class="table">
            <thead><tr><th>Name</th><th>Zeit</th><th>Kategorie</th><th>Tag</th><th>Erzielt</th><th>Erfasst</th><th>Admin</th><th>Aktion</th></tr></thead>
            <tbody>
              <template x-for="entry in rows" :key="entry.id">
                <tr>
                  <td data-label="Name" x-text="entry.pseudonym"></td>
                  <td data-label="Zeit" x-text="`${entry.time_seconds.toFixed(3)}s`"></td>
                  <td data-label="Kategorie" x-text="entry.category"></td>
                  <td data-label="Tag" x-text="dayLabel(entry.festival_day)"></td>
                  <td data-label="Erzielt" x-text="formatDate(entry.achieved_at ?? entry.created_at)"></td>
                  <td data-label="Erfasst" x-text="formatDate(entry.created_at)"></td>
                  <td data-label="Admin" x-text="entry.created_by ?? 'Unbekannt'"></td>
                  <td data-label="Aktion"><button class="danger-button" type="button" :disabled="deletingId === entry.id" @click="deleteEntry(entry.id)" x-text="deletingId === entry.id ? 'Löscht…' : 'Löschen'"></button></td>
                </tr>
              </template>
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </main>

  <script type="module">
    import Alpine from "alpinejs";
    import { berlinDateTimeLocalToIso, festivalDayForLocalDateTime, formatBerlinDateTimeLocal, moveLocalDateTimeToFestivalDay } from "../lib/berlinTime";
    import { exchangeCodeForToken, readCognitoCallback } from "../lib/cognitoAuth";

    const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL ?? "https://api.trichter.me";
    const COGNITO_DOMAIN = import.meta.env.PUBLIC_COGNITO_DOMAIN ?? "";
    const CLIENT_ID = import.meta.env.PUBLIC_COGNITO_CLIENT_ID ?? "";
    const REDIRECT_URI = import.meta.env.PUBLIC_COGNITO_REDIRECT_URI ?? `${window.location.origin}/admin`;
    const PKCE_VERIFIER_KEY = "trichter_admin_pkce_verifier";
    const ACCESS_TOKEN_KEY = "trichter_admin_access_token";
    const DAY_LABELS = { Wednesday: "Mittwoch", Thursday: "Donnerstag", Friday: "Freitag", Saturday: "Samstag", Sunday: "Sonntag" };

    function randomString(length) {
      const alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-._~";
      const randomValues = crypto.getRandomValues(new Uint8Array(length));
      return Array.from(randomValues, (value) => alphabet[value % alphabet.length]).join("");
    }

    function base64UrlEncode(bytes) {
      return btoa(String.fromCharCode(...bytes)).replace(/\+/g, "-").replace(/\//g, "_").replace(/=+$/g, "");
    }

    async function createCodeChallenge(verifier) {
      const digest = await crypto.subtle.digest("SHA-256", new TextEncoder().encode(verifier));
      return base64UrlEncode(new Uint8Array(digest));
    }

    window.adminApp = function adminApp() {
      return {
        accessToken: "",
        statusMessage: "",
        statusIsError: false,
        loadingRows: false,
        saving: false,
        deletingId: "",
        rows: [],
        categories: ["0.33l", "0.5l", "1.0l"],
        festivalDays: ["Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
        form: { pseudonym: "", time_seconds: "", category: "0.33l", festival_day: "Wednesday", achieved_local: "" },

        async init() {
          this.resetForm();
          const callback = readCognitoCallback(window.location.href);
          if (callback.error) {
            window.history.replaceState({}, "", window.location.pathname);
            sessionStorage.removeItem(PKCE_VERIFIER_KEY);
            this.setStatus("Cognito-Anmeldung wurde abgebrochen oder abgelehnt.", true);
            return;
          }
          if (!callback.code) {
            const existing = sessionStorage.getItem(ACCESS_TOKEN_KEY);
            if (existing) {
              this.accessToken = existing;
              await this.loadRows();
            }
            return;
          }

          const verifier = sessionStorage.getItem(PKCE_VERIFIER_KEY);
          window.history.replaceState({}, "", window.location.pathname);
          if (!verifier) {
            this.setStatus("PKCE-Verifier fehlt. Bitte erneut anmelden.", true);
            return;
          }
          try {
            this.accessToken = await exchangeCodeForToken(callback.code, verifier, {
              domain: COGNITO_DOMAIN,
              clientId: CLIENT_ID,
              redirectUri: REDIRECT_URI
            });
            sessionStorage.setItem(ACCESS_TOKEN_KEY, this.accessToken);
            sessionStorage.removeItem(PKCE_VERIFIER_KEY);
          } catch (error) {
            sessionStorage.removeItem(PKCE_VERIFIER_KEY);
            this.setStatus(error instanceof Error ? error.message : "Cognito-Anmeldung fehlgeschlagen. Bitte erneut anmelden.", true);
            return;
          }
          await this.loadRows();
        },

        resetForm() {
          const localNow = formatBerlinDateTimeLocal();
          const festivalDay = festivalDayForLocalDateTime(localNow) ?? "Wednesday";
          const achievedLocal = festivalDayForLocalDateTime(localNow)
            ? localNow
            : moveLocalDateTimeToFestivalDay(localNow, festivalDay) ?? localNow;
          this.form = { pseudonym: "", time_seconds: "", category: "0.33l", festival_day: festivalDay, achieved_local: achievedLocal };
        },

        syncFestivalDayFromDate() {
          const suggested = festivalDayForLocalDateTime(this.form.achieved_local);
          if (suggested) {
            this.form.festival_day = suggested;
            this.setStatus("");
          } else {
            this.setStatus("Bitte ein Datum von Mittwoch bis Sonntag wählen.", true);
          }
        },

        syncDateFromFestivalDay() {
          const adjusted = moveLocalDateTimeToFestivalDay(this.form.achieved_local, this.form.festival_day);
          if (adjusted) {
            this.form.achieved_local = adjusted;
            this.setStatus("");
          } else {
            this.setStatus("Bitte zuerst eine gültige Erzielungszeit wählen.", true);
          }
        },

        setStatus(message, isError = false) {
          this.statusMessage = message;
          this.statusIsError = isError;
        },

        async login() {
          this.setStatus("");
          if (!COGNITO_DOMAIN || !CLIENT_ID) {
            this.setStatus("Cognito-Umgebungsvariablen fehlen.", true);
            return;
          }
          const verifier = randomString(64);
          sessionStorage.setItem(PKCE_VERIFIER_KEY, verifier);
          const target = new URL(`${COGNITO_DOMAIN}/oauth2/authorize`);
          target.searchParams.set("response_type", "code");
          target.searchParams.set("client_id", CLIENT_ID);
          target.searchParams.set("redirect_uri", REDIRECT_URI);
          target.searchParams.set("scope", "openid");
          target.searchParams.set("code_challenge_method", "S256");
          target.searchParams.set("code_challenge", await createCodeChallenge(verifier));
          window.location.href = target.toString();
        },

        logout() {
          this.accessToken = "";
          this.rows = [];
          sessionStorage.removeItem(ACCESS_TOKEN_KEY);
          sessionStorage.removeItem(PKCE_VERIFIER_KEY);
        },

        async loadRows() {
          this.loadingRows = true;
          try {
            const response = await fetch(`${API_BASE_URL}/api/admin/highscores`, { headers: { Authorization: `Bearer ${this.accessToken}` } });
            if (response.status === 401 || response.status === 403) {
              this.logout();
              throw new Error("Die Sitzung ist abgelaufen oder es fehlen Admin-Rechte.");
            }
            if (!response.ok) throw new Error("Highscores konnten nicht geladen werden");
            this.rows = (await response.json()).highscores ?? [];
          } catch (error) {
            this.setStatus(error instanceof Error ? error.message : "Highscores konnten nicht geladen werden", true);
          } finally {
            this.loadingRows = false;
          }
        },

        async createEntry() {
          const festivalDay = festivalDayForLocalDateTime(this.form.achieved_local);
          if (!festivalDay || festivalDay !== this.form.festival_day) {
            this.setStatus("Festivaltag und Erzielungsdatum stimmen nicht überein.", true);
            return;
          }
          const achievedAt = berlinDateTimeLocalToIso(this.form.achieved_local);
          if (!achievedAt) {
            this.setStatus("Bitte eine gültige Berliner Erzielungszeit wählen. Zeiten in der übersprungenen DST-Stunde sind ungültig.", true);
            return;
          }
          this.saving = true;
          this.setStatus("");
          try {
            const response = await fetch(`${API_BASE_URL}/api/highscores`, {
              method: "POST",
              headers: { "Content-Type": "application/json", Authorization: `Bearer ${this.accessToken}` },
              body: JSON.stringify({ pseudonym: this.form.pseudonym, time_seconds: Number(this.form.time_seconds), category: this.form.category, festival_day: this.form.festival_day, achieved_at: achievedAt })
            });
            if (response.status === 401 || response.status === 403) {
              this.logout();
              this.setStatus("Die Sitzung ist abgelaufen oder es fehlen Admin-Rechte.", true);
              return;
            }
            if (!response.ok) {
              this.setStatus(response.status === 422 ? "Bitte alle Eingaben und Zeitformate prüfen." : "Eintrag konnte nicht gespeichert werden.", true);
              return;
            }
            this.setStatus("Eintrag gespeichert.");
            this.resetForm();
            await this.loadRows();
          } catch {
            this.setStatus("Eintrag konnte wegen eines Netzwerkfehlers nicht gespeichert werden.", true);
          } finally {
            this.saving = false;
          }
        },

        async deleteEntry(id) {
          if (this.deletingId || !window.confirm("Diesen Highscore wirklich löschen?")) return;
          this.deletingId = id;
          try {
            const response = await fetch(`${API_BASE_URL}/api/highscores/${id}`, { method: "DELETE", headers: { Authorization: `Bearer ${this.accessToken}` } });
            if (response.status === 401 || response.status === 403) {
              this.logout();
              this.setStatus("Die Sitzung ist abgelaufen oder es fehlen Admin-Rechte.", true);
              return;
            }
            if (!response.ok) {
              this.setStatus("Eintrag konnte nicht gelöscht werden.", true);
              return;
            }
            this.setStatus("Eintrag gelöscht.");
            await this.loadRows();
          } catch {
            this.setStatus("Eintrag konnte wegen eines Netzwerkfehlers nicht gelöscht werden.", true);
          } finally {
            this.deletingId = "";
          }
        },

        dayLabel(day) {
          return DAY_LABELS[day] ?? day;
        },

        formatDate(value) {
          const date = new Date(value);
          return Number.isNaN(date.getTime()) ? "Unbekannt" : new Intl.DateTimeFormat("de-DE", { timeZone: "Europe/Berlin", dateStyle: "short", timeStyle: "short" }).format(date);
        }
      };
    };

    window.Alpine = Alpine;
    Alpine.start();
  </script>
</BaseLayout>
