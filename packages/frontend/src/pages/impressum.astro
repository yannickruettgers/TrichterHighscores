---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="trichter.me | Impressum">
  <main>
    <section class="hero legal-page">
      <a class="back-link" href="/">Zurück zum Leaderboard</a>
      <div>
        <h1>Impressum</h1>
        <p>Diese Seite ist als Platzhalter für die finalen rechtlichen Angaben vorbereitet.</p>
      </div>
    </section>

    <section class="panel legal-page">
      <p>Betreiber: trichter.me Team</p>
      <p>Adresse und Kontaktangaben werden vor dem produktiven Go-Live mit den finalen Daten ersetzt.</p>
      <p>Bis dahin dient diese Seite als technische Zielseite für die Footer-Verlinkung und spätere Freigabe.</p>
    </section>
  </main>
</BaseLayout>