---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="trichter.me - Parookaville Leaderboard">
  <main class="board-page" x-data="leaderboardApp()" x-init="load()">
    <div class="neon-splash" aria-hidden="true"></div>

    <header class="board-header">
      <div class="brand-lockup">
        <div class="brand-logo-shell">
          <img class="brand-logo" src="/branding/logo-mascot.svg" alt="trichter.me Maskottchen" />
        </div>
        <div>
          <p class="eyebrow">Parookaville</p>
          <h1>Leaderboard</h1>
        </div>
      </div>
      <a class="button-link button-primary" href="/admin">Admin</a>
    </header>

    <section class="leaderboard-shell panel" id="leaderboard" aria-labelledby="leaderboard-title">
      <h2 id="leaderboard-title" class="sr-only">Highscore-Auswahl</h2>
      <div class="filter-layout">
        <fieldset class="filter-block">
          <legend class="filter-label">Kategorie</legend>
          <div class="toggle-row toggle-pills">
            <template x-for="categoryOption in categories" :key="categoryOption">
              <button type="button" :class="selectedCategory === categoryOption ? 'active' : ''" :aria-pressed="selectedCategory === categoryOption" @click="selectedCategory = categoryOption" x-text="categoryOption"></button>
            </template>
          </div>
        </fieldset>

        <fieldset class="filter-block">
          <legend class="filter-label">Wertung</legend>
          <div class="toggle-row toggle-pills secondary-pills">
            <button type="button" :class="selectedDay === 'overall' ? 'active' : ''" :aria-pressed="selectedDay === 'overall'" @click="selectedDay = 'overall'">Gesamtes Festival</button>
            <template x-for="day in festivalDays" :key="day">
              <button type="button" :class="selectedDay === day ? 'active' : ''" :aria-pressed="selectedDay === day" @click="selectedDay = day" x-text="dayLabel(day)"></button>
            </template>
          </div>
        </fieldset>
      </div>

      <div class="status-card" x-show="loading" x-cloak role="status">
        <strong>Highscores werden geladen...</strong>
        <p>Die aktuelle Wertung wird frisch aus der API gezogen.</p>
      </div>
      <div class="status-card error-card" x-show="error" x-cloak role="alert">
        <strong>Leaderboard gerade nicht erreichbar</strong>
        <p x-text="error"></p>
      </div>
      <div class="status-card empty-card" x-show="!loading && !error && visibleRows().length === 0" x-cloak>
        <strong>Noch kein Eintrag in dieser Sicht</strong>
        <p>Wechsle den Tag oder die Kategorie, um andere Festivalzeiten anzuzeigen.</p>
      </div>

      <section class="podium-section" x-show="!loading && !error && topThree().length > 0" x-cloak aria-labelledby="podium-title">
        <h2 id="podium-title" class="section-title">Podium</h2>
        <div class="podium-grid">
          <template x-for="(entry, index) in topThree()" :key="entry.id">
            <article class="podium-card" :class="`podium-rank-${index + 1}`">
              <span class="podium-rank" x-text="`#${index + 1}`"></span>
              <img class="podium-avatar" :src="avatarUrl(entry.pseudonym)" :alt="`Avatar von ${entry.pseudonym}`" />
              <strong x-text="entry.pseudonym"></strong>
              <p x-text="dayLabel(entry.festival_day)"></p>
              <span class="podium-time" x-text="`${entry.time_seconds.toFixed(3)}s`"></span>
            </article>
          </template>
        </div>
      </section>

      <section class="list-section" x-show="!loading && !error && visibleRows().length > 0" x-cloak aria-labelledby="all-ranks-title">
        <div class="list-head">
          <div>
            <p class="eyebrow">Jeder Versuch zählt</p>
            <h2 id="all-ranks-title">Alle Platzierungen</h2>
          </div>
          <p x-text="`${visibleRows().length} Ergebnisse`"></p>
        </div>
        <div class="leaderboard-list">
          <template x-for="(entry, idx) in visibleRows()" :key="entry.id">
            <article class="leaderboard-row">
              <span class="rank-badge" x-text="`#${idx + 1}`"></span>
              <img class="avatar" :src="avatarUrl(entry.pseudonym)" :alt="`Avatar von ${entry.pseudonym}`" />
              <div class="row-copy">
                <div class="row-headline">
                  <strong x-text="entry.pseudonym"></strong>
                  <span class="day-chip" x-text="dayLabel(entry.festival_day)"></span>
                </div>
                <p x-text="`${entry.category} Kategorie`"></p>
              </div>
              <span class="time-pill" x-text="`${entry.time_seconds.toFixed(3)}s`"></span>
            </article>
          </template>
        </div>
      </section>
    </section>

    <aside class="beer-card panel" aria-labelledby="beer-title">
      <div>
        <p class="eyebrow">Support the Dose</p>
        <h2 id="beer-title">Buy me a beer</h2>
      </div>
      <a class="button-link button-primary" href="https://www.paypal.me/yannickruettgers" target="_blank" rel="noopener noreferrer">Bier ausgeben</a>
    </aside>

    <footer class="legal">
      <nav class="legal-links" aria-label="Rechtliches">
        <a href="/impressum">Impressum</a>
        <a href="/datenschutz">Datenschutz</a>
      </nav>
      <p>trichter.me · Parookaville Edition</p>
    </footer>
  </main>

  <script type="module">
    import Alpine from "alpinejs";
    import { avatarDataUri } from "../lib/avatar";
    import { filterHighscores, uniquePodium } from "../lib/leaderboard";

    const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL ?? "https://api.trichter.me";
    const DAY_LABELS = { Wednesday: "Mittwoch", Thursday: "Donnerstag", Friday: "Freitag", Saturday: "Samstag", Sunday: "Sonntag" };

    window.leaderboardApp = function leaderboardApp() {
      return {
        loading: false,
        error: "",
        rows: [],
        categories: ["0.33l", "0.5l", "1.0l"],
        festivalDays: ["Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
        selectedCategory: "0.33l",
        selectedDay: "overall",
        async load() {
          this.loading = true;
          this.error = "";
          try {
            const response = await fetch(`${API_BASE_URL}/api/highscores`);
            if (!response.ok) throw new Error("Highscores konnten nicht geladen werden");
            const data = await response.json();
            this.rows = data.highscores ?? [];
          } catch (error) {
            this.error = error instanceof Error ? error.message : "Unbekannter Fehler";
          } finally {
            this.loading = false;
          }
        },
        visibleRows() {
          return filterHighscores(this.rows, this.selectedCategory, this.selectedDay);
        },
        topThree() {
          return uniquePodium(this.visibleRows());
        },
        dayLabel(day) {
          return DAY_LABELS[day] ?? day;
        },
        avatarUrl(seed) {
          return avatarDataUri(seed);
        }
      };
    };

    window.Alpine = Alpine;
    Alpine.start();
  </script>
</BaseLayout>
