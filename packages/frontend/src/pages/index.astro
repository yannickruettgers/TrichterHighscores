---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="trichter.me | Parookaville Highscores">
  <main
    class="board-page"
    x-data="leaderboardApp()"
    x-init="load()"
  >
    <section class="board-header">
      <div class="brand-lockup">
        <img
          class="brand-logo"
          src="/branding/logo-mascot.svg"
          alt="trichter.me Logo und Maskottchen"
        />
        <div>
          <p class="eyebrow">Parookaville</p>
          <h1>Leaderboard</h1>
        </div>
      </div>
      <div class="board-meta">
        <div class="meta-pill">
          <span>Ansicht</span>
          <strong x-text="selectedCategory"></strong>
        </div>
        <div class="meta-pill">
          <span>Wertung</span>
          <strong x-text="selectedDayLabel()"></strong>
        </div>
        <div class="meta-pill">
          <span>Einträge</span>
          <strong x-text="visibleRows().length"></strong>
        </div>
      </div>
    </section>

    <section class="leaderboard-shell panel" id="leaderboard">
      <div class="filter-layout">
        <div class="filter-block">
          <span class="filter-label">Kategorie</span>
          <div class="toggle-row toggle-pills">
            <template x-for="categoryOption in categories" :key="categoryOption">
              <button
                type="button"
                :class="selectedCategory === categoryOption ? 'active' : ''"
                @click="selectedCategory = categoryOption"
                x-text="categoryOption"
              ></button>
            </template>
          </div>
        </div>

        <div class="filter-block">
          <span class="filter-label">Wertung</span>
          <div class="toggle-row toggle-pills secondary-pills">
            <button
              type="button"
              :class="selectedDay === 'overall' ? 'active' : ''"
              @click="selectedDay = 'overall'"
            >
              Overall Festival
            </button>
            <template x-for="day in festivalDays" :key="day">
              <button
                type="button"
                :class="selectedDay === day ? 'active' : ''"
                @click="selectedDay = day"
                x-text="day"
              ></button>
            </template>
          </div>
        </div>
      </div>

      <template x-if="loading">
        <div class="status-card">
          <strong>Highscores werden geladen...</strong>
          <p>Die aktuelle Wertung wird frisch aus der API gezogen.</p>
        </div>
      </template>

      <template x-if="error">
        <div class="status-card error-card">
          <strong>Leaderboard gerade nicht erreichbar</strong>
          <p x-text="error"></p>
        </div>
      </template>

      <template x-if="!loading && !error && visibleRows().length === 0">
        <div class="status-card empty-card">
          <strong>Noch kein Eintrag in dieser Sicht</strong>
          <p>Wechsle den Tag oder die Kategorie, um andere Festivalzeiten anzuzeigen.</p>
        </div>
      </template>

      <section class="podium-section" x-show="!loading && !error && topThree().length > 0">
        <template x-if="topThree().length > 0">
          <div class="podium-grid">
            <template x-for="entry in podiumOrder()" :key="entry.id">
              <article class="podium-card" :class="podiumClass(entry.id)">
                <span class="podium-rank" x-text="podiumLabel(entry.id)"></span>
                <img class="podium-avatar" :src="avatarUrl(entry.pseudonym)") alt="Avatar" />
                <strong x-text="entry.pseudonym"></strong>
                <p x-text="entry.festival_day"></p>
                <span class="podium-time" x-text="`${entry.time_seconds.toFixed(3)}s`"></span>
              </article>
            </template>
          </div>
        </template>
      </section>

      <section class="list-section" x-show="!loading && !error && visibleRows().length > 0">
        <div class="list-head">
          <h2>Alle Platzierungen</h2>
          <p>Sortiert nach Zeit, bei Gleichstand nach älterem Eintrag.</p>
        </div>

        <div class="leaderboard-list">
          <template x-for="(entry, idx) in visibleRows()" :key="entry.id">
            <article class="leaderboard-row">
              <span class="rank-badge" x-text="`#${idx + 1}`"></span>
              <img class="avatar" :src="avatarUrl(entry.pseudonym)" alt="Avatar" />
              <div class="row-copy">
                <div class="row-headline">
                  <strong x-text="entry.pseudonym"></strong>
                  <span class="day-chip" x-text="entry.festival_day"></span>
                </div>
                <p x-text="`${entry.category} Kategorie`"></p>
              </div>
              <span class="time-pill" x-text="`${entry.time_seconds.toFixed(3)}s`"></span>
            </article>
          </template>
        </div>
      </section>
    </section>

    <footer class="legal">
      <p>Nur Pseudonyme, Zeiten und Kategorien. Keine Klarnamen auf dem Leaderboard.</p>
      <nav class="legal-links" aria-label="Rechtliches">
        <a href="/impressum">Impressum</a>
        <a href="/datenschutz">Datenschutz</a>
      </nav>
    </footer>
  </main>

  <script type="module">
    import Alpine from "alpinejs";

    const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL ?? "https://api.trichter.me";

    window.leaderboardApp = function leaderboardApp() {
      return {
        loading: false,
        error: "",
        rows: [],
        categories: ["0.33l", "0.5l", "1.0l"],
        festivalDays: ["Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
        selectedCategory: "0.33l",
        selectedDay: "overall",

        async load() {
          this.loading = true;
          this.error = "";

          try {
            const response = await fetch(`${API_BASE_URL}/api/highscores`);
            if (!response.ok) {
              throw new Error("Highscores konnten nicht geladen werden");
            }

            const data = await response.json();
            this.rows = data.highscores ?? [];
          } catch (err) {
            this.error = err instanceof Error ? err.message : "Unbekannter Fehler";
          } finally {
            this.loading = false;
          }
        },

        visibleRows() {
          return this.rows.filter((entry) => {
            const categoryMatch = entry.category === this.selectedCategory;
            const dayMatch = this.selectedDay === "overall" ? true : entry.festival_day === this.selectedDay;
            return categoryMatch && dayMatch;
          });
        },

        topThree() {
          return this.visibleRows().slice(0, 3);
        },

        remainingRows() {
          return this.visibleRows().slice(3);
        },

        podiumOrder() {
          const top = this.topThree();
          if (top.length === 1) {
            return [top[0]];
          }
          if (top.length === 2) {
            return [top[1], top[0]];
          }

          return [top[1], top[0], top[2]];
        },

        podiumLabel(id) {
          const index = this.topThree().findIndex((entry) => entry.id === id);
          return `#${index + 1}`;
        },

        podiumClass(id) {
          const index = this.topThree().findIndex((entry) => entry.id === id);
          if (index === 0) {
            return "champion";
          }
          if (index === 1) {
            return "runner-up";
          }
          return "third-place";
        },

        selectedDayLabel() {
          return this.selectedDay === "overall" ? "Overall Festival" : this.selectedDay;
        },

        avatarUrl(seed) {
          return `https://api.dicebear.com/10.x/fun-emoji/svg?seed=${encodeURIComponent(seed)}`;
        }
      };
    };

    window.Alpine = Alpine;
    Alpine.start();
  </script>
</BaseLayout>
